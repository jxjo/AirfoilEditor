{
    "python.analysis.extraPaths": ["./airfoileditor"],
    "python.analysis.exclude": ["build", "dist", ".pytest_cache", "tests", "images", "icons", "**/__pycache__"],
    "python.analysis.typeCheckingMode": "off",
    "markdown.preview.fontSize": 10,
    "python.testing.pytestArgs": [],            // ["-m", "not slow"] to skip slow tests
    "python.testing.unittestEnabled": false,
    "python.testing.pytestEnabled": true,
    "debugpy.debugJustMyCode": true,
    "python.REPL.enableREPLSmartSend": false,
    "cSpell.words": [
        "iair",
        "improv",
        "nsteps",
        "qtext"
    ],
    "chat.tools.terminal.autoApprove": {
        "git stash": true,
        "C:/Users/jochen/AppData/Local/Python/pythoncore-3.13-64/python.exe": true,
        "/^python -m pytest tests/test_constraints_model\\.py -q$/": {
            "approve": true,
            "matchCommandLine": true
        },
        "%{Write-Host": true,
        "Show-Conflict": true,
        "git -C \"e:\\GitHub\\AirfoilEditor\"": true
    }
}